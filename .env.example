# =============================================================
# .env.local 작성 예시 — 실제 값으로 교체 후 .env.local로 저장
# 이 파일은 커밋 대상입니다 (실제 시크릿 값 포함 금지)
# =============================================================

# Neon Postgres (Vercel Storage)
# Vercel Dashboard > Storage > Neon > .env.local 탭에서 복사
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# NextAuth.js v5
# 생성 명령: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
# 로컬 개발 전용. Vercel 배포 시에는 NEXTAUTH_URL 을 삭제하거나 실제 URL로 변경하라.
# trustHost: true 설정으로 Vercel은 x-forwarded-host 헤더에서 URL을 자동 감지한다.
NEXTAUTH_URL=http://localhost:3000

# 초기 관리자 계정 (db:seed 시 사용)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-before-seed
